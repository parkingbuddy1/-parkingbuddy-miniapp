/* 物业端首页 - 暗黑风格 */
.home-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0F172A 0%, #1E293B 50%, #0F172A 100%);
  padding: 0 32rpx 32rpx;
}

.topbar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  z-index: 100;
}

.welcome {
  font-size: 28rpx;
  color: #94A3B8;
}

.company {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-top: 4rpx;
}

.logout-icon {
  font-size: 40rpx;
  color: #94A3B8;
  padding: 20rpx;
}

.lot-tabs {
  margin-bottom: 24rpx;
}

.lot-scroll {
  white-space: nowrap;
}

.lot-tab {
  display: inline-block;
  padding: 16rpx 32rpx;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: #94A3B8;
  background: rgba(30, 41, 59, 0.5);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  border-radius: 32rpx;
}

.lot-tab.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  border-color: transparent;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
  color: #94A3B8;
}

.spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid rgba(249, 115, 22, 0.2);
  border-top-color: #F97316;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.lot-card {
  background: linear-gradient(135deg, rgba(249, 115, 22, 0.15) 0%, rgba(26, 86, 219, 0.1) 100%);
  border: 1rpx solid rgba(249, 115, 22, 0.3);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.lot-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.lot-address {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

.lot-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(148, 163, 184, 0.15);
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.stat-num.highlight {
  color: #F97316;
}

.stat-label {
  font-size: 22rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.switch-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(30, 41, 59, 0.6);
  border: 1rpx solid rgba(249, 115, 22, 0.2);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.switch-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.switch-desc {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.grid-card {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.grid-item {
  background: rgba(30, 41, 59, 0.6);
  border: 1rpx solid rgba(148, 163, 184, 0.15);
  border-radius: 20rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.grid-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #FFFFFF;
  margin-bottom: 16rpx;
}

.grid-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.grid-label {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 4rpx;
}

.task-card, .quick-card {
  background: rgba(30, 41, 59, 0.6);
  border: 1rpx solid rgba(148, 163, 184, 0.15);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.task-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 20rpx;
}

.task-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(148, 163, 184, 0.1);
}

.task-item:last-child {
  border-bottom: none;
}

.task-left {
  flex: 1;
}

.task-name {
  font-size: 28rpx;
  color: #FFFFFF;
}

.task-desc {
  font-size: 22rpx;
  color: #64748B;
  margin-top: 4rpx;
}

.task-badge {
  min-width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: rgba(148, 163, 184, 0.2);
  color: #94A3B8;
  font-size: 24rpx;
  border-radius: 20rpx;
  padding: 0 16rpx;
  margin-right: 16rpx;
}

.task-badge.urgent {
  background: #EF4444;
  color: #FFFFFF;
  font-weight: 600;
}

.task-arrow {
  color: #64748B;
  font-size: 32rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 20rpx;
}

.quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
  background: rgba(15, 23, 42, 0.5);
  border-radius: 16rpx;
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.quick-label {
  font-size: 24rpx;
  color: #94A3B8;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 32rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.empty-desc {
  font-size: 24rpx;
  color: #64748B;
  margin-top: 8rpx;
}
