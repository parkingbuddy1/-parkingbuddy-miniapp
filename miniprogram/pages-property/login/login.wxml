<view class="login-page">
  <!-- 顶部装饰 -->
  <view class="header">
    <view class="logo">粤停汇 · 物业端</view>
    <view class="subtitle">{{mode === 'login' ? '管理车场，让闲置车位产生价值' : '注册账号，等待平台审核'}}</view>
  </view>

  <view class="form-card">
    <!-- 注册时显示 -->
    <block wx:if="{{mode === 'register'}}">
      <view class="form-item">
        <view class="label">物业公司/业委会</view>
        <input class="input" placeholder="如：万科物业-科技园管理处"
               value="{{name}}" bindinput="onNameInput" />
      </view>
      <view class="form-item">
        <view class="label">联系人姓名</view>
        <input class="input" placeholder="您的真实姓名"
               value="{{contactName}}" bindinput="onContactInput" />
      </view>
    </block>

    <view class="form-item">
      <view class="label">手机号</view>
      <input class="input" type="number" maxlength="11" placeholder="请输入手机号"
             value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-item">
      <view class="label">密码</view>
      <view class="password-row">
        <input class="input" password="{{!showPassword}}" placeholder="至少6位"
               value="{{password}}" bindinput="onPasswordInput" />
        <view class="eye-icon" bindtap="togglePassword">
          <text>{{showPassword ? '🙈' : '👁️'}}</text>
        </view>
      </view>
    </view>

    <block wx:if="{{mode === 'register'}}">
      <view class="form-item">
        <view class="label">确认密码</view>
        <input class="input" password="{{!showPassword}}" placeholder="再次输入密码"
               value="{{confirmPassword}}" bindinput="onConfirmInput" />
      </view>
    </block>

    <view class="agreement" bindtap="toggleAgreement">
      <view class="checkbox {{agreement ? 'checked' : ''}}">{{agreement ? '✓' : ''}}</view>
      <text>我已阅读并同意《粤停汇物业服务协议》</text>
    </view>

    <button class="btn-primary" loading="{{loading}}"
            disabled="{{loading}}" bindtap="handleSubmit">
      {{mode === 'login' ? '登 录' : '注 册'}}
    </button>

    <view class="switch-mode" bindtap="switchMode">
      {{mode === 'login' ? '还没有账号？立即注册' : '已有账号？返回登录'}}
    </view>
  </view>
</view>
