/* 物业端登录页 - 暗黑风格统一 */
.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0F172A 0%, #1E293B 100%);
  padding: 80rpx 48rpx 48rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.logo {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  display: inline-block;
}

.subtitle {
  font-size: 26rpx;
  color: #94A3B8;
  margin-top: 20rpx;
}

.form-card {
  background: rgba(30, 41, 59, 0.6);
  backdrop-filter: blur(20rpx);
  border: 1rpx solid rgba(249, 115, 22, 0.15);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
}

.form-item {
  margin-bottom: 36rpx;
}

.label {
  font-size: 24rpx;
  color: #94A3B8;
  margin-bottom: 12rpx;
}

.input {
  background: rgba(15, 23, 42, 0.5);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  color: #FFFFFF;
  font-size: 30rpx;
}

.password-row {
  position: relative;
}

.eye-icon {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 36rpx;
  padding: 10rpx;
}

.agreement {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #94A3B8;
  margin: 32rpx 0;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 1rpx solid #64748B;
  border-radius: 8rpx;
  margin-right: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: transparent;
}

.checkbox.checked {
  background: #F97316;
  border-color: #F97316;
  color: #FFFFFF;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #F97316 0%, #FB923C 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  padding: 28rpx 0;
  margin-top: 24rpx;
  border: none;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.switch-mode {
  text-align: center;
  font-size: 26rpx;
  color: #1A56DB;
  margin-top: 32rpx;
}

.debug-link {
  text-align: center;
  font-size: 22rpx;
  color: #64748B;
  margin-top: 48rpx;
  padding: 16rpx;
  border: 1rpx dashed rgba(148, 163, 184, 0.3);
  border-radius: 12rpx;
}
