.debug-page {
  min-height: 100vh;
  background: #0F172A;
  padding: 40rpx 32rpx;
}

.header {
  margin-bottom: 40rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.subtitle {
  font-size: 24rpx;
  color: #94A3B8;
  margin-top: 8rpx;
}

.actions {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.btn {
  flex: 1;
  background: linear-gradient(135deg, #F97316, #FB923C);
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 12rpx;
  padding: 20rpx 0;
  border: none;
}

.btn-secondary {
  background: rgba(148, 163, 184, 0.2);
  color: #94A3B8;
}

.logs {
  background: rgba(15, 23, 42, 0.5);
  border: 1rpx solid rgba(148, 163, 184, 0.2);
  border-radius: 16rpx;
  padding: 24rpx;
}

.log-item {
  font-family: monospace;
  font-size: 22rpx;
  line-height: 1.6;
  margin-bottom: 12rpx;
  word-break: break-all;
}

.log-time {
  color: #64748B;
  margin-right: 12rpx;
}

.log-msg {
  color: #E2E8F0;
}

.log-item.log-success .log-msg { color: #10B981; }
.log-item.log-error .log-msg { color: #EF4444; }
.log-item.log-info .log-msg { color: #94A3B8; }
