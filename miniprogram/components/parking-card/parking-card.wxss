/* Parking Card v4 - 蓝字橙字白底风格 */
.pcard{margin:0 4rpx 24rpx;overflow:hidden}

.pcard-map{position:relative;height:220rpx;overflow:hidden}
.pcard-map .map-img{width:100%;height:100%}
.pcard-map-fb{width:100%;height:100%;display:flex;flex-direction:column;align-items:center;justify-content:center;background:linear-gradient(135deg,#EFF6FF,#DBEAFE);gap:8rpx}
.pcard-map-emoji{font-size:48rpx}.pcard-map-hint{font-size:20rpx;color:var(--text-muted)}

.pcard-badge{position:absolute;top:14rpx;left:14rpx;background:var(--accent);color:#fff;font-size:18rpx;padding:4rpx 12rpx;border-radius:6rpx;font-weight:600}
.pcard-dist{position:absolute;bottom:14rpx;right:14rpx;background:rgba(0,0,0,.55);color:#fff;font-size:18rpx;padding:4rpx 14rpx;border-radius:20rpx}

.pcard-body{padding:22rpx}

/* 名称+价格同行 */
.pcard-row{margin-bottom:12rpx}
.pcard-name{font-size:28rpx;font-weight:700;color:var(--primary);flex:1;margin-right:16rpx}
.pcard-min-price{display:flex;align-items:baseline;flex-shrink:0}
.min-sym{color:var(--accent);font-size:22rpx;font-weight:700}
.min-num{color:var(--accent);font-size:36rpx;font-weight:800;line-height:1}
.min-unit{color:var(--text-muted);font-size:20rpx;margin-left:4rpx}

.pcard-addr{display:flex;align-items:flex-start;margin-bottom:14rpx}
.addr-icon{font-size:18rpx;margin-right:6rpx;flex-shrink:0}
.addr-text{font-size:22rpx;color:var(--text-secondary);line-height:1.4;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical}

.pcard-tags{display:flex;flex-wrap:wrap;gap:8rpx;margin-bottom:16rpx}
.pcard-tag{font-size:18rpx;color:var(--text-secondary);background:#F1F5F9;padding:4rpx 10rpx;border-radius:4rpx;max-width:200rpx;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.pcard-tag-more{font-size:18rpx;color:var(--accent);padding:4rpx 10rpx}

/* 热度 */
.pcard-heat{padding-top:16rpx;border-top:1rpx solid var(--border-subtle)}
.heat-dot{width:8rpx;height:8rpx;border-radius:50%;background:#CBD5E1;margin-right:6rpx}.heat-dot.on{background:var(--success);box-shadow:0 0 6rpx rgba(16,185,129,.4)}
.heat-text{font-size:18rpx;color:var(--text-muted);margin-left:8rpx}
.pcard-pkg-count{font-size:20rpx;color:var(--accent);font-weight:600}
