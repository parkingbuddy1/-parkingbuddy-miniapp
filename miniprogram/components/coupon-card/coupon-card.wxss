/* 优惠券卡片 - 蓝底橙字 */
.c-card{display:flex;border-radius:24rpx;overflow:hidden;margin-bottom:24rpx;background:linear-gradient(135deg,#1A56DB,#3B82F6);color:#fff;box-shadow:0 8rpx 24rpx rgba(26,86,219,.2);position:relative}
.c-card.expired{background:linear-gradient(135deg,#94A3B8,#CBD5E1);box-shadow:none}
.c-card.used{background:linear-gradient(135deg,#64748B,#94A3B8);box-shadow:none}
.c-left{width:200rpx;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32rpx 16rpx;border-right:2rpx dashed rgba(255,255,255,.3)}
.c-amount{font-size:28rpx;font-weight:700}
.c-num{font-size:56rpx;font-weight:800;color:#F97316}
.c-term{font-size:20rpx;color:rgba(255,255,255,.7);margin-top:6rpx}
.c-id{font-size:18rpx;color:rgba(255,255,255,.5);margin-top:8rpx}
.c-divider{width:2rpx}
.c-right{flex:1;padding:28rpx 24rpx;display:flex;flex-direction:column;justify-content:center}
.c-title{font-size:28rpx;font-weight:700;color:#F97316}
.c-desc{font-size:22rpx;color:rgba(255,255,255,.8);margin-top:6rpx}
.c-expire{display:flex;align-items:center;gap:8rpx;margin-top:12rpx}
.c-exp-label{font-size:20rpx;color:rgba(255,255,255,.6)}
.c-exp-date{font-size:22rpx;font-weight:600;color:#F97316}
.c-use-btn{padding:8rpx 20rpx;border-radius:20rpx;background:rgba(249,115,22,.15);color:#F97316;font-size:22rpx;font-weight:600;align-self:flex-start;margin-top:12rpx}
.c-badge{position:absolute;top:16rpx;right:16rpx;padding:4rpx 14rpx;border-radius:16rpx;font-size:18rpx;background:rgba(255,255,255,.2);color:#fff}
.c-badge.used{background:rgba(255,255,255,.3)}
