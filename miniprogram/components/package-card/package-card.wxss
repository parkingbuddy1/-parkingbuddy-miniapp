/* Package Card v6 - 简洁版 + 选中态 */
.pkg{position:relative;overflow:visible;border:2rpx solid transparent;transition:border-color .2s}
.pkg-selected{border-color:var(--primary);background:rgba(26,86,219,.03)}
.pkg-body{padding:24rpx}

.pkg-name{font-size:26rpx;font-weight:600;color:var(--primary);display:block;margin-bottom:4rpx}
.pkg-meta{font-size:20rpx;color:var(--text-muted);margin-top:4rpx}

/* 原价现价同行 */
.pkg-price-row{display:flex;align-items:center;gap:12rpx;margin-top:16rpx;padding-top:14rpx;border-top:1rpx dashed var(--border-subtle)}
.pkg-orig{font-size:20rpx;color:var(--text-muted);text-decoration:line-through}
.pkg-discount{font-size:18rpx;color:#fff;background:#EF4444;padding:2rpx 10rpx;border-radius:8rpx;font-weight:600}
.pkg-cur{font-size:30rpx;font-weight:800;color:var(--accent);margin-left:auto}

/* 单次停放价 */
.pkg-peruse{margin-top:10rpx;font-size:20rpx;color:#059669;font-weight:600}
