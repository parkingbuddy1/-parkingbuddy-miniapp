<wxs module="filters" src="../../utils/filters.wxs"></wxs>
<view class="page">
  <view class="search-bar">
    <t-search
      placeholder="搜索停车场、地址或片区..."
      value="{{keyword}}"
      focus="{{true}}"
      bind:change="onSearchInput"
      bind:submit="onSearch"
      bind:clear="onClear"
    />
  </view>

  <!-- 搜索历史 -->
  <view wx:if="{{!keyword && history.length > 0}}" class="history-section">
    <view class="section-header flex-between">
      <text class="section-title">搜索历史</text>
      <text class="clear-btn" bindtap="onClearHistory">清除</text>
    </view>
    <view class="history-tags flex flex-wrap">
      <view
        class="history-tag"
        wx:for="{{history}}"
        wx:key="index"
        bindtap="onTapHistory"
        data-keyword="{{item}}"
      >{{item}}</view>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view wx:if="{{keyword && !loading}}" class="result-section">
    <view class="result-header" wx:if="{{results.length > 0}}">
      找到 <text class="result-count">{{total}}</text> 个停车场
    </view>
    <view wx:if="{{results.length > 0}}" class="result-list">
      <view
        class="result-item"
        wx:for="{{results}}"
        wx:key="_id"
        bindtap="onTapResult"
        data-id="{{item._id}}"
      >
        <text class="result-name">{{item.name}}</text>
        <text class="result-address text-ellipsis">📍 {{item.address}}</text>
        <view class="result-footer">
          <text class="result-packages">{{item.packageCount || 0}}个套餐</text>
          <text class="price-value">¥{{filters.toFixed(item.minPrice)}}/月起</text>
        </view>
      </view>
    </view>
    <t-empty wx:else icon="search" description="未找到相关停车场" />
  </view>
</view>
