/* 确认订单 v3 - 蓝字橙字白底风格 */
.page{background:var(--bg-deep);min-height:100vh}

.o-parking-name{font-size:28rpx;font-weight:600;color:var(--primary)}

.stepper-btn{width:56rpx;height:56rpx;display:flex;align-items:center;justify-content:center;border-radius:50%;background:#F1F5F9;font-size:36rpx;color:var(--text-primary)}
.stepper-btn.disabled{opacity:.3}

/* ========== 车辆选择卡片 ========== */
.vehicle-pick {
  padding: 20rpx 24rpx;
  margin-top: 20rpx;
  border: 2rpx solid rgba(249,115,22,0.2);
  background: rgba(249,115,22,0.04);
  border-radius: 20rpx;
}
.vehicle-icon { font-size: 36rpx; }
.vehicle-plate {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 2rpx;
}
.vehicle-meta {
  font-size: 22rpx;
  color: var(--text-secondary);
}
.switch-hint {
  font-size: 22rpx;
  color: var(--accent);
}

/* ========== 车辆选择弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 200;
  backdrop-filter: blur(4px);
}
.vehicle-picker-card {
  position: fixed;
  left: 16rpx; right: 16rpx;
  bottom: 60rpx;
  background: #fff;
  border-radius: 28rpx;
  z-index: 201;
  overflow: hidden;
  box-shadow: 0 -12rpx 48rpx rgba(0,0,0,0.1);
}
.picker-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx 16rpx;
  border-bottom: 1rpx solid var(--border-subtle);
}
.picker-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--primary);
}
.picker-close {
  width: 48rpx; height: 48rpx;
  border-radius: 50%;
  background: #F1F5F9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--text-secondary);
}
.picker-body {
  max-height: 360rpx;
  padding: 16rpx 0;
}
.pick-item {
  padding: 20rpx 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background 0.15s;
}
.pick-item.active {
  background: rgba(249,115,22,0.06);
}
.pick-item:active {
  background: #F1F5F9;
}
.pick-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}
.pick-plate {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 2rpx;
}
.pick-meta {
  font-size: 22rpx;
  color: var(--text-secondary);
}
.pick-check {
  width: 40rpx; height: 40rpx;
  border-radius: 50%;
  background: var(--accent);
  color: #fff;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
}
.picker-footer {
  padding: 16rpx 28rpx;
  border-top: 1rpx solid var(--border-subtle);
}
.add-vehicle-link {
  text-align: center;
  padding: 14rpx;
  color: var(--accent);
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 20rpx;
  border: 2rpx dashed rgba(249,115,22,0.25);
}

/* 底部 — 普通模式 */
.bot-bar{position:fixed;bottom:0;left:0;right:0;background:rgba(255,255,255,.97);display:flex;align-items:center;padding:14rpx 24rpx;border-top:1rpx solid var(--border-subtle);z-index:100;backdrop-filter:blur(20px);gap:10rpx}
/*.invite-btn 旧样式保留兼容，拼团用新 bot-bar-group */
.invite-btn{background:rgba(249,115,22,.08);color:var(--accent);font-size:22rpx;font-weight:600;padding:14rpx 20rpx;border-radius:40rpx;text-align:center;border:1rpx solid rgba(249,115,22,.2)}
.cart-btn{font-size:22rpx;color:var(--text-muted);padding:12rpx 16rpx;border-radius:32rpx;border:1rpx solid var(--border-subtle);background:var(--bg-card);white-space:nowrap;flex-shrink:0}
.cart-btn-sm{font-size:20rpx;color:var(--text-muted);padding:6rpx 14rpx;border-radius:24rpx;border:1rpx solid var(--border-subtle);background:var(--bg-card);white-space:nowrap;flex-shrink:0}
.pay-btn{background:linear-gradient(135deg,#F97316,#FB923C);color:#fff;font-size:26rpx;font-weight:700;padding:18rpx 24rpx;border-radius:40rpx;text-align:center;box-shadow:0 6rpx 20rpx rgba(249,115,22,.25)}

/* 底部 — 拼团模式（两行） */
.bot-bar-group{position:fixed;bottom:0;left:0;right:0;background:rgba(255,255,255,.97);padding:14rpx 24rpx;border-top:1rpx solid var(--border-subtle);z-index:100;backdrop-filter:blur(20px);display:flex;flex-direction:column;gap:8rpx}
.group-foot-row{display:flex;align-items:center}
.group-save-tip{font-size:20rpx;color:#059669;background:rgba(5,150,105,0.08);padding:2rpx 10rpx;border-radius:8rpx;margin-left:8rpx}
.invite-btn-new{flex:1;background:linear-gradient(135deg,#F97316,#FB923C);color:#fff;font-size:24rpx;font-weight:700;padding:16rpx 16rpx;border-radius:40rpx;text-align:center;border:none;box-shadow:0 6rpx 20rpx rgba(249,115,22,.25)}
.invite-btn-new::after{border:none}
