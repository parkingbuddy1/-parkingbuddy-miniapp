<view class="page">
  <block wx:if="{{favorites.length>0}}">
    <parking-card wx:for="{{favorites}}" wx:key="_id" parking="{{item}}" bind:click="onTapParking"/>
  </block>
  <view wx:else class="empty-wrap flex-center flex-col">
    <text class="empty-icon">🤍</text>
    <text class="empty-title">暂无收藏</text>
    <text class="empty-desc">浏览停车场时点击收藏即可保存</text>
    <view class="empty-btn" bindtap="onGoHome">去逛逛</view>
  </view>
  <view class="safe-bottom bottom-spacer"></view>
</view>
