.page{min-height:100vh;background:var(--bg-deep);padding-bottom:40rpx}
.form-item{margin-bottom:24rpx}
.form-label{font-size:26rpx;color:var(--text-primary);font-weight:600;display:block;margin-bottom:12rpx}
.form-input{width:100%;height:80rpx;background:#F1F5F9;border-radius:16rpx;padding:0 20rpx;font-size:28rpx;box-sizing:border-box}
.form-textarea{width:100%;min-height:200rpx;background:#F1F5F9;border-radius:16rpx;padding:16rpx 20rpx;font-size:26rpx;box-sizing:border-box}
.form-count{text-align:right;font-size:22rpx;color:var(--text-muted);margin-top:8rpx}
