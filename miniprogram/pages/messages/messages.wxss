/* 消息中心 */
.page{background:var(--bg-deep);min-height:100vh;padding-top:0}

/* 加载/空状态 */
.loading-wrap{padding-top:200rpx;text-align:center}
.empty-wrap{display:flex;flex-direction:column;align-items:center;padding-top:160rpx}
.empty-emoji{font-size:72rpx;margin-bottom:20rpx;opacity:.5}
.empty-title{font-size:28rpx;color:var(--text-secondary);margin-bottom:8rpx}
.empty-sub{font-size:22rpx;color:var(--text-muted)}

/* 顶部操作栏 */
.top-bar{display:flex;align-items:center;justify-content:space-between;padding:16rpx 24rpx 8rpx}
.top-bar-left{flex:1}
.top-bar-hint{font-size:22rpx;color:var(--text-secondary)}
.read-all-btn{font-size:22rpx;color:var(--primary);padding:8rpx 20rpx;background:var(--bg-card);border-radius:20rpx}
.edit-btn{font-size:24rpx;color:var(--primary);padding:8rpx 24rpx;background:var(--bg-card);border-radius:20rpx;font-weight:600}
.edit-btn.active{color:#fff;background:var(--primary)}

/* 消息列表 */
.msg-list{padding:0 24rpx 16rpx}
.msg-item{
  display:flex;align-items:flex-start;
  background:var(--bg-card);border-radius:var(--radius-lg);
  padding:24rpx;margin-bottom:12rpx;
  position:relative;
  transition:all .2s;
}
.msg-item:active{background:var(--bg-card-hover)}

/* 编辑模式：勾选框 */
.msg-item.edit-mode{padding-left:20rpx}
.msg-check{
  width:44rpx;height:44rpx;border-radius:50%;
  border:2rpx solid var(--border-subtle);
  display:flex;align-items:center;justify-content:center;
  flex-shrink:0;margin-right:16rpx;margin-top:14rpx;
  transition:all .15s;
}
.msg-check.checked{border-color:var(--primary);background:var(--primary)}
.msg-check.checked text{color:#fff;font-size:24rpx;font-weight:700}

.msg-avatar{
  width:72rpx;height:72rpx;border-radius:20rpx;
  background:var(--primary-light);
  display:flex;align-items:center;justify-content:center;
  font-size:34rpx;flex-shrink:0;margin-right:20rpx;
}

.msg-body{flex:1;min-width:0;overflow:hidden}
.msg-top{display:flex;align-items:center;margin-bottom:6rpx}
.msg-label{font-size:20rpx;color:var(--primary);background:var(--primary-light);padding:2rpx 12rpx;border-radius:6rpx;margin-right:12rpx}
.msg-time{font-size:20rpx;color:var(--text-muted);flex-shrink:0}
.msg-title{display:block;font-size:26rpx;font-weight:700;color:var(--text-primary);margin-bottom:4rpx;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.msg-content{
  display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:2;
  font-size:22rpx;color:var(--text-secondary);line-height:1.5;overflow:hidden
}

/* 未读红点 */
.msg-dot{
  width:14rpx;height:14rpx;border-radius:50%;
  background:#EF4444;
  position:absolute;top:32rpx;right:24rpx
}

/* 已读样式 */
.msg-item.read{opacity:.7}
.msg-item.read .msg-dot{display:none}

/* 底部删除栏 */
.bottom-del-bar{
  position:fixed;bottom:0;left:0;right:0;
  padding:16rpx 24rpx;padding-bottom:calc(16rpx + env(safe-area-inset-bottom));
  background:var(--bg-card);border-top:1rpx solid var(--border-subtle);
  display:flex;justify-content:center;
  transform:translateY(100%);transition:transform .25s;
  z-index:100;
}
.bottom-del-bar.show{transform:translateY(0)}
.bottom-del-btn{
  font-size:26rpx;color:var(--text-muted);padding:16rpx 48rpx;
  border-radius:40rpx;background:var(--bg-card-hover);
  display:flex;align-items:center;gap:8rpx;transition:all .15s;
}
.bottom-del-btn.active{color:#fff;background:#EF4444;border-color:#EF4444}

/* 底部安全区 */
.safe-area{height:40rpx}
.safe-area.with-bar{height:120rpx}
