.page{min-height:100vh;background:var(--bg-deep)}
.list-wrap{padding:20rpx}
.fb-card{background:var(--bg-card);border-radius:16rpx;padding:20rpx;margin-bottom:16rpx}
.fb-meta{display:flex;justify-content:space-between;margin-bottom:12rpx}
.fb-phone{font-size:24rpx;color:var(--primary);font-weight:600}
.fb-tag-adopt{font-size:22rpx;color:#059669;background:rgba(5,150,105,0.1);padding:2rpx 12rpx;border-radius:6rpx}
.fb-tag-hold{font-size:22rpx;color:#F97316;background:rgba(249,115,22,0.1);padding:2rpx 12rpx;border-radius:6rpx}
.fb-content{font-size:26rpx;color:var(--text-primary);line-height:1.8;margin-bottom:8rpx;background:#F8FAFC;padding:16rpx;border-radius:12rpx}
.fb-reason{font-size:22rpx;color:var(--text-muted);font-style:italic}
