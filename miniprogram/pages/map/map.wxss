.map-page{width:100vw;height:100vh;position:relative}
.parking-map{width:100%;height:100%}

/* 顶部栏 */
.map-topbar{position:absolute;top:0;left:0;right:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:90rpx 24rpx 16rpx;background:linear-gradient(180deg,rgba(26,26,46,0.95),transparent)}
.map-back{font-size:28rpx;color:#fff;font-weight:600}
.map-stats{font-size:24rpx;color:rgba(255,255,255,0.8);background:rgba(26,26,46,0.8);padding:8rpx 20rpx;border-radius:20rpx}
.map-stats-num{color:#F97316;font-weight:700}

/* 筛选按钮 */
.map-filters{position:absolute;bottom:60rpx;left:50%;transform:translateX(-50%);z-index:100;display:flex;gap:12rpx;background:rgba(26,26,46,0.95);padding:10rpx 16rpx;border-radius:30rpx;backdrop-filter:blur(10px)}
.map-filter-btn{font-size:22rpx;color:rgba(255,255,255,0.6);padding:8rpx 18rpx;border-radius:20rpx;display:flex;align-items:center;gap:6rpx;transition:all 0.2s}
.map-filter-btn.on{background:rgba(249,115,22,0.2);color:#fff;font-weight:600}
.map-dot{width:12rpx;height:12rpx;border-radius:50%;display:inline-block}

/* 图例提示 */
.map-legend-hint{position:absolute;bottom:120rpx;left:50%;transform:translateX(-50%);z-index:100;display:flex;align-items:center;background:rgba(26,26,46,0.85);padding:6rpx 20rpx;border-radius:16rpx;font-size:20rpx;color:rgba(255,255,255,0.7)}
