/* 车主认证页面样式 */
.page{min-height:100vh;background:var(--bg-page,#F5F7FA);padding-bottom:40rpx}

/* 进度条 */
.steps-bar{position:relative;height:8rpx;background:#E5E7EB;margin:80rpx 32rpx 48rpx}
.steps-progress{position:absolute;top:0;left:0;height:100%;background:linear-gradient(90deg,#1A56DB,#4F8AF7);border-radius:4rpx;transition:width .4s}
.steps-dots{position:absolute;top:50%;left:0;right:0;transform:translateY(-50%);display:flex;justify-content:space-between}
.steps-dot{width:40rpx;height:40rpx;border-radius:50%;background:#E5E7EB;display:flex;align-items:center;justify-content:center;font-size:20rpx;color:#999;transition:all .3s}
.steps-dot.active{background:linear-gradient(135deg,#1A56DB,#4F8AF7);color:#fff;box-shadow:0 4rpx 12rpx rgba(26,86,219,.3)}
.steps-dot.done{background:#1A56DB}
.dot-text{font-weight:700}

/* 步骤卡片 */
.step-card{margin:0 32rpx;padding:48rpx 32rpx;background:#fff;border-radius:24rpx;box-shadow:0 4rpx 24rpx rgba(0,0,0,.06)}
.step-icon{font-size:56rpx;text-align:center;margin-bottom:16rpx}
.done-icon{animation: bounce .6s}
@keyframes bounce{0%,100%{transform:scale(1)}50%{transform:scale(1.3)}}
.step-title{font-size:34rpx;font-weight:700;color:#1F2937;text-align:center;margin-bottom:8rpx}
.step-desc{font-size:26rpx;color:#6B7280;text-align:center;margin-bottom:32rpx;line-height:1.5}

/* 表单 */
.form-group{margin-bottom:24rpx}
.form-label{display:block;font-size:26rpx;font-weight:600;color:#374151;margin-bottom:8rpx}
.form-input{width:100%;height:88rpx;background:#F9FAFB;border:2rpx solid #E5E7EB;border-radius:16rpx;padding:0 24rpx;font-size:28rpx;color:#1F2937;box-sizing:border-box}
.form-input:focus{border-color:#1A56DB;background:#fff}
.privacy-tip{text-align:center;font-size:22rpx;color:#9CA3AF;margin:8rpx 0 24rpx;padding:12rpx;background:#F0FDF4;border-radius:12rpx}

/* 短信验证 */
.sms-row{display:flex;gap:16rpx;align-items:center;margin-bottom:0}
.sms-input-wrap{flex:1}
.sms-input{padding-right:16rpx}
.sms-btn{flex:0 0 180rpx;height:88rpx;background:linear-gradient(135deg,#1A56DB,#4F8AF7);color:#fff;font-size:24rpx;border-radius:16rpx;border:none;display:flex;align-items:center;justify-content:center;padding:0 12rpx}
.sms-btn-disabled{background:#D1D5DB;color:#9CA3AF}
.sms-btn-verified{background:#059669;color:#fff}
.sms-verify-btn{margin-top:8rpx;color:#059669;border-color:#A7F3D0}

/* 按钮 */
.btn-block{width:100%;height:88rpx;border-radius:16rpx;font-size:28rpx;font-weight:600;margin-top:16rpx;display:flex;align-items:center;justify-content:center;box-sizing:border-box}
.btn-primary{background:linear-gradient(135deg,#1A56DB,#4F8AF7);color:#fff;border:none;box-shadow:0 4rpx 16rpx rgba(26,86,219,.25)}
.btn-primary:active{opacity:.85;transform:scale(.98)}
.btn-outline{background:#fff;color:#1A56DB;border:2rpx solid #DBEAFE;margin-top:12rpx}
.btn-outline:active{background:#EFF6FF}

/* 信息卡片 */
.info-card{background:#F9FAFB;border-radius:16rpx;padding:24rpx;margin-bottom:24rpx}
.info-row{display:flex;align-items:center;padding:8rpx 0;font-size:26rpx;color:#1F2937}
.info-key{color:#6B7280;min-width:120rpx}

/* 人脸识别 */
.face-preview{padding:48rpx;text-align:center;background:#F0FDF4;border-radius:16rpx;margin-bottom:24rpx}
.face-check{font-size:32rpx;color:#059669;font-weight:700}
.face-icon-area{width:160rpx;height:160rpx;margin:0 auto 32rpx;background:#F3F4F6;border-radius:50%;display:flex;align-items:center;justify-content:center}
.face-icon-big{font-size:80rpx}

/* 上传 */
.upload-area{border:3rpx dashed #D1D5DB;border-radius:24rpx;padding:64rpx 32rpx;text-align:center;background:#FAFBFC;margin-bottom:24rpx}
.upload-area:active{background:#F3F4F6}
.upload-icon{font-size:64rpx;display:block;margin-bottom:16rpx}
.upload-text{font-size:28rpx;color:#374151;display:block;margin-bottom:8rpx}
.upload-hint{font-size:22rpx;color:#9CA3AF}
.upload-tip{text-align:center;font-size:24rpx;color:#1A56DB;padding:16rpx}
.license-preview{width:100%;border-radius:16rpx;box-shadow:0 2rpx 12rpx rgba(0,0,0,.1);margin-bottom:16rpx}

/* OCR */
.ocr-loading{padding:48rpx 0;text-align:center}
.ocr-spinner{width:56rpx;height:56rpx;margin:0 auto 24rpx;border:4rpx solid #E5E7EB;border-top-color:#1A56DB;border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.ocr-status{font-size:26rpx;color:#6B7280}
.ocr-result-card{background:#F9FAFB;border-radius:16rpx;padding:24rpx;margin-bottom:16rpx}
.ocr-row{display:flex;justify-content:space-between;align-items:center;padding:12rpx 0;border-bottom:1rpx solid #E5E7EB}
.ocr-row:last-child{border:none}
.ocr-key{font-size:24rpx;color:#6B7280}
.ocr-val{font-size:24rpx;color:#1F2937;font-weight:600}
.ocr-success{text-align:center;font-size:28rpx;color:#059669;font-weight:600;padding:16rpx}
.ocr-confirm-tip{text-align:center;font-size:24rpx;color:#B45309;padding:12rpx 16rpx;background:#FFF3E0;border-radius:12rpx;margin:8rpx 0 16rpx}
.ocr-fail-msg{text-align:center;padding:32rpx 24rpx;margin:16rpx 0;background:#FFF3E0;border-radius:12rpx;font-size:26rpx;color:#9A3412}

/* 校验 */
.check-item{display:flex;align-items:center;gap:12rpx;padding:16rpx 20rpx;margin-bottom:12rpx;border-radius:12rpx;font-size:26rpx;color:#1F2937}
.check-item.pass{background:#F0FDF4}
.check-item.warn{background:#FFF7ED;color:#9A3412}
.check-icon{font-size:28rpx}
.check-msg{display:block;text-align:center;font-size:24rpx;color:#6B7280;padding:16rpx;margin-top:16rpx;background:#FFF3E0;border-radius:12rpx}

/* 审核 */
.audit-card{text-align:center;padding:32rpx;margin:24rpx 0;background:#FFF7ED;border-radius:16rpx}
.audit-icon{font-size:48rpx;display:block;margin-bottom:12rpx}
.audit-title{font-size:28rpx;font-weight:700;color:#1F2937;display:block;margin-bottom:8rpx}
.audit-desc{font-size:24rpx;color:#6B7280;display:block;margin-bottom:8rpx}
.audit-hint{font-size:22rpx;color:#9CA3AF}

/* 完成 */
.done-benefits{margin:24rpx 0}
.benefit-item{padding:16rpx 20rpx;margin-bottom:8rpx;background:#F9FAFB;border-radius:12rpx;font-size:26rpx;color:#374151}

/* 已有认证 */
.verify-card{margin:80rpx 32rpx;padding:48rpx 32rpx;background:#fff;border-radius:24rpx;text-align:center;box-shadow:0 4rpx 24rpx rgba(0,0,0,.06)}
.verify-success-icon{font-size:72rpx;margin-bottom:16rpx}
.verify-success-title{font-size:36rpx;font-weight:700;color:#059669;margin-bottom:16rpx}
.verify-success-info{font-size:26rpx;color:#6B7280;padding:4rpx 0}

.flex-center{display:flex;align-items:center;justify-content:center}
